<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#18181B"
    android:padding="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="┌[Lenovo]\n└[~/screenshots]\n> ls -la"
            android:textColor="#E5E7EB"
            android:fontFamily="@font/jetbrains_mono"
            android:textSize="14sp"
            android:layout_marginBottom="16dp"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginBottom="12dp"
            android:background="#2C2C32"
            android:padding="1dp"
            android:src="@drawable/ssh1"
            android:scaleType="fitCenter"
            android:cropToPadding="true"
            android:elevation="0dp"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginBottom="12dp"
            android:background="#2C2C32"
            android:padding="1dp"
            android:src="@drawable/ssh2"
            android:scaleType="fitCenter"
            android:cropToPadding="true"
            android:elevation="0dp"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:layout_marginBottom="12dp"
            android:background="#2C2C32"
            android:padding="1dp"
            android:src="@drawable/ssh3"
            android:scaleType="fitCenter"
            android:cropToPadding="true"
            android:elevation="0dp"/>
    </LinearLayout>
</ScrollView>