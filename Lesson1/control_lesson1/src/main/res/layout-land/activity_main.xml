<?xml version="1.0" encoding="utf-8"?>
<TableLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/material_dynamic_neutral10"
    android:padding="16dp"
    android:stretchColumns="1">

    <TableRow
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.4"
            android:contentDescription="Profile Image"
            android:scaleType="centerCrop"
            android:src="@drawable/astolfo_hotline_image" />

        <TableLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="16dp"
            android:stretchColumns="1">

            <TableRow>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Contact details"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp" />
            </TableRow>

            <TableRow>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Name:"
                    android:textColor="#888888" />

                <EditText
                    android:id="@+id/name_input_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="type here..."
                    android:textColorHint="@color/material_dynamic_neutral20"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />
            </TableRow>

            <TableRow>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Organisation:"
                    android:textColor="#888888" />

                <EditText
                    android:id="@+id/organisation_input_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="type here..."
                    android:textColorHint="@color/material_dynamic_neutral20"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />
            </TableRow>

            <TableRow>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📞 Phone:"
                    android:textColor="#888888" />

                <EditText
                    android:id="@+id/phone_input_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="+7 (___)___-__-__"
                    android:inputType="phone"
                    android:maxLength="18"
                    android:textColorHint="@color/material_dynamic_neutral20"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />
            </TableRow>

            <TableRow>

                <Button
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="SAVE"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp" />
            </TableRow>
        </TableLayout>
    </TableRow>
</TableLayout>